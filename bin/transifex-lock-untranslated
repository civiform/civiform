#!/usr/bin/env python3

# DOC: Add the locked text to strings in transifex when the label `lock-transifex-strings` is included on the pull request.
# DOC: Only locks strings that are not already locked and do not have translation instructions or context.

import argparse
import os
import sys
import time

try:
    import requests
except ImportError:
    print("ERROR: Python module 'requests' is required. Install it with 'pip install requests'.")
    sys.exit(1)

BASE_URL = "https://rest.api.transifex.com"


def paginate(url, headers, params=None):
    results = []
    while url:
        response = requests.get(url, headers=headers, params=params)
        response.raise_for_status()
        body = response.json()
        results.extend(body.get("data", []))
        url = body.get("links", {}).get("next")
        params = None
    return results


def get_resources(project_id, headers):
    url = f"{BASE_URL}/resources"
    params = {"filter[project]": project_id}
    return paginate(url, headers, params)


def find_resource_string_by_key(resource_id, key, headers):
    url = f"{BASE_URL}/resource_strings"
    params = {
        "filter[resource]": resource_id,
        "filter[key]": key,
    }
    matches = paginate(url, headers, params)
    return matches[0] if matches else None


def update_tags(string_id, tags, headers):
    url = f"{BASE_URL}/resource_strings/{string_id}"
    payload = {
        "data": {
            "id": string_id,
            "type": "resource_strings",
            "attributes": {
                "tags": tags,
            },
        }
    }
    response = requests.patch(url, headers=headers, json=payload)
    response.raise_for_status()
    return response.json()


def parse_args():
    parser = argparse.ArgumentParser(
        description=(
            "Tag Transifex source strings with 'locked' for message keys added in the PR diff, "
            "skipping strings that are already locked or have translation instructions/context."
        )
    )
    parser.add_argument("--org-slug", default="civiform", help="Transifex organization slug")
    parser.add_argument("--project-slug", default="civiform", help="Transifex project slug")
    parser.add_argument(
        "--api-token",
        help="Transifex API token. If omitted, reads from TRANSIFEX_API_TOKEN environment variable.",
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="List strings that would be tagged without updating Transifex.",
    )
    parser.add_argument(
        "--diff-file",
        help=(
            "Path to a file containing the messages diff (unified diff format). "
            "If omitted, reads from the MESSAGES_DIFF environment variable. "
            "Useful for local testing."
        ),
    )
    parser.add_argument(
        "--pause",
        type=float,
        default=0.1,
        help="Seconds to pause between updates to avoid rate limits.",
    )
    return parser.parse_args()


def main():
    args = parse_args()
    api_token = args.api_token or os.environ.get("TRANSIFEX_API_TOKEN")

    if args.diff_file:
        with open(args.diff_file) as f:
            messages_diff = f.read()
    else:
        messages_diff = os.environ.get("MESSAGES_DIFF", "")

    if not messages_diff:
        print("No changes detected in messages file. Exiting without making API calls.")
        sys.exit(0)
    if not api_token:
        print("ERROR: must provide a Transifex API token via --api-token or TRANSIFEX_API_TOKEN")
        sys.exit(1)

    headers = {
        "Authorization": f"Bearer {api_token}",
        "Content-Type": "application/vnd.api+json",
    }

    keys_to_lock = set()
    for line in messages_diff.splitlines():
        # Skip patch header lines like "+++ b/server/conf/i18n/messages".
        if not line.startswith("+") or line.startswith("+++"):
            continue
        line = line[1:]
        if "=" in line:
            key = line.split("=", 1)[0].strip()
            keys_to_lock.add(key)

    if not keys_to_lock:
        print("No added message keys found in diff. Exiting without making API calls.")
        sys.exit(0)

    project_id = f"o:{args.org_slug}:p:{args.project_slug}"

    print(f"Target project: {project_id}")
    print(f"Found {len(keys_to_lock)} added message keys in diff.")
    print("\nFetching resources...")

    resources = get_resources(project_id, headers)
    print(f"Found {len(resources)} resources.")

    remaining_keys = set(keys_to_lock)
    total_tagged = 0
    total_skipped_locked = 0
    total_skipped_context = 0
    total_errors = 0

    for resource in resources:
        if not remaining_keys:
            break

        resource_id = resource["id"]
        resource_name = resource.get("attributes", {}).get("name", resource_id)
        print(f"\nProcessing resource: {resource_name} ({len(remaining_keys)} keys to look up)")

        for key in sorted(remaining_keys):
            try:
                resource_string = find_resource_string_by_key(resource_id, key, headers)
                if resource_string is None:
                    continue

                # Key found in this resource; don't search subsequent resources for it.
                remaining_keys.discard(key)

                attributes = resource_string.get("attributes", {})
                current_tags = attributes.get("tags") or []
                context = (attributes.get("context") or "").strip()
                instructions = (attributes.get("instructions") or "").strip()
                string_id = resource_string["id"]

                if "locked" in current_tags:
                    total_skipped_locked += 1
                    continue

                if context or instructions:
                    total_skipped_context += 1
                    continue

                print(f"    Locking {key} ({string_id})")
                if not args.dry_run:
                    update_tags(string_id, current_tags + ["locked"], headers)
                    time.sleep(args.pause)
                total_tagged += 1
            except requests.exceptions.HTTPError as exc:
                print(f"    Error processing key {key}: {exc}")
                total_errors += 1

    print(
        f"\nFinished. total_tagged={total_tagged}, total_skipped_locked={total_skipped_locked}, "
        f"total_skipped_context_or_instructions={total_skipped_context}, "
        f"keys_not_found={len(remaining_keys)}, total_errors={total_errors}"
    )
    if remaining_keys:
        print(f"Keys not found in any resource: {sorted(remaining_keys)}")

    if total_errors:
        sys.exit(1)


if __name__ == "__main__":
    main()
